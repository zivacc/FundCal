{
  "name": "fund-fee-calculator",
  "version": "1.0.0",
  "description": "基金费率计算器 - 多基金费用对比与交叉点分析",
  "type": "module",
  "devDependencies": {
    "pinyin-pro": "^3.28.0",
    "wrangler": "^4"
  },
  "scripts": {
    "dev": "node scripts/dev-server.js",
    "api": "node scripts/serve-fund-api.js 3457",
    "serve": "npx serve . -p 3456",
    "build-search-index": "node scripts/build-search-index.js",
    "build-feeder-index": "node scripts/build-feeder-index.js",
    "build-fund-stats": "node scripts/build-fund-stats.js",
    "build-allfund": "node scripts/build-allfund-from-db.js",
    "build-all": "npm run build-allfund && npm run build-search-index && npm run build-feeder-index && npm run build-fund-stats",
    "migrate:crawler": "node scripts/migrate-crawler-to-db.js",
    "deploy": "bash scripts/deploy.sh",
    "build:workers": "node scripts/build-workers.js",
    "upload-kv": "node scripts/upload-kv.js",
    "upload-kv:preview": "node scripts/upload-kv.js --preview",
    "dev:workers": "npm run build:workers && npx wrangler dev",
    "deploy:workers": "npm run build:workers && npx wrangler deploy",
    "sync:fund-basic": "node scripts/nav/sync-fund-basic.js",
    "sync:fund-nav": "node scripts/nav/sync-fund-nav.js",
    "query:nav": "node scripts/nav/query-nav.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0"
  }
}
